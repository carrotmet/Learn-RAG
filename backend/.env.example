OPENROUTER_API_KEY=your-openrouter-api-key

# 默认 LLM 模型（OpenRouter）
DEFAULT_MODEL=openai/gpt-3.5-turbo

# ========== 嵌入模型配置 ==========
# 嵌入模型提供商: openrouter / huggingface / openai / fake
# - openrouter: 使用 OpenRouter 在线嵌入 API（需联网）
# - huggingface: 使用本地 HuggingFace 模型（需预下载到服务器）
# - openai: 使用 OpenAI 官方嵌入 API（需联网）
# - fake: 使用本地哈希伪嵌入（无网络，仅测试用，语义质量差）
EMBEDDING_PROVIDER=openrouter

# 嵌入模型名称（根据提供商选择）
# - openrouter: nvidia/llama-nemotron-embed-vl-1b-v2:free, openai/text-embedding-3-small, etc.
# - huggingface: sentence-transformers/all-MiniLM-L6-v2（需预下载）
# - openai: text-embedding-3-small, text-embedding-3-large, etc.
# - fake: 任意值（本地哈希伪嵌入）
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# 向量数据库路径
CHROMA_DB_PATH=./chroma_db

# 文档上传目录
UPLOAD_DIR=./uploads
